---
import Base from '../../layouts/Base.astro';
import CaseCard from '../../components/CaseCard.astro';
import CtaSection from '../../components/CtaSection.astro';
import { getCollection } from 'astro:content';

const studies = (await getCollection('work', ({ data }) => !data.draft))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const logoMap: Record<string, { src: string; height: string }> = {
  'breeze-oral-care':  { src: '/images/logos/breeze.svg',  height: '20px' },
  'pilou':             { src: '/images/logos/pilou.png',   height: '22px' },
  'odie':              { src: '/images/logos/odie.png',    height: '24px' },
  'wake':              { src: '/images/logos/wake.png',    height: '20px' },
  'footprint':         { src: '/images/logos/footprint.png', height: '22px' },
  'barrys-bootcamp':   { src: '/images/logos/barrys.png',  height: '18px' },
  'klipster':          { src: '/images/logos/klipster.png', height: '18px' },
  'morphus':           { src: '/images/logos/morphus.svg',  height: '14px' },
  'squadup':           { src: '/images/logos/squadup.svg',  height: '22px' },
};
---
<Base title="Work — Case Studies" description="Case studies from healthcare, insurance, and finance. Predictable delivery from concept to market." fullWidth>

  <div class="case-studies" style="padding-top: 2rem;">
    <h2 class="section-heading">Products we shaped and <em>shipped</em></h2>
    <p class="section-sub">From "should we build this?" to production — in industries where the stakes are real.</p>
    <div class="case-grid">
      {studies.map(study => (
        <CaseCard
          slug={study.id}
          image={study.data.image}
          imageAlt={study.data.imageAlt}
          category={study.data.category}
          client={study.data.client}
          description={study.data.description}
          partnership={study.data.partnership}
          logo={logoMap[study.id]}
        />
      ))}
    </div>
  </div>

  <CtaSection />

</Base>
