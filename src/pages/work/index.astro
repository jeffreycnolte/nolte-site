---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const studies = (await getCollection('work', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = await getCollection('categories', ({ data }) => data.scope === 'work' || data.scope === 'both');
---
<Base title="Work" description="Case studies from healthcare, insurance, and other regulated industries. Predictable delivery from concept to market.">

  <div class="category-header">
    <span class="eyebrow">Case Studies</span>
    <h1>Delivery That Speaks for <em>Itself</em></h1>
    <p>Every engagement is forecasted, priced per delivery, and measured against our predictions.</p>
  </div>

  <div class="work-categories">
    <a href="/work" class="active">All</a>
    {categories.map(cat => (
      <a href={`/work/category/${cat.id}`}>{cat.data.title}</a>
    ))}
  </div>

  <div class="work-grid">
    {studies.map(study => (
      <a class="work-card" href={`/work/${study.id}`}>
        {study.data.metrics && (
          <div class="work-card-preview">
            <div class="mini-metrics">
              <div class="mini-metric">
                <span class="mini-metric-value">{study.data.metrics.deliveries}</span>
                <span class="mini-metric-label">Deliveries</span>
              </div>
              <div class="mini-metric">
                <span class="mini-metric-value">{study.data.metrics.accuracy}</span>
                <span class="mini-metric-label">Accuracy</span>
              </div>
            </div>
          </div>
        )}
        <span class="work-card-type">{study.data.category}</span>
        <h3>{study.data.client}</h3>
        <p>{study.data.description}</p>
        <div class="work-card-meta">
          <span>{study.data.status}</span>
          <span>{study.data.partnership}</span>
        </div>
      </a>
    ))}
  </div>

</Base>
