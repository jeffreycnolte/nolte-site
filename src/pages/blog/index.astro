---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = await getCollection('categories', ({ data }) => data.scope === 'blog' || data.scope === 'both');
---
<Base title="Blog — Predictable Software Delivery" description="How we think about predictive delivery, flow metrics, and building software that ships on time and on budget.">

  <div class="category-header">
    <span class="eyebrow">Writing</span>
    <h1>From the <em>Studio</em></h1>
    <p>How we think about predictive delivery, flow metrics, and building software where failure is not an option.</p>
  </div>

  <div class="work-categories">
    <a href="/blog" class="active">All</a>
    {categories.map(cat => (
      <a href={`/blog/category/${cat.id}`}>{cat.data.title}</a>
    ))}
  </div>

  <ul class="blog-list">
    {posts.map(post => (
      <li>
        <article class="blog-item">
          <a href={`/blog/${post.id}`}>
            <time datetime={post.data.date.toISOString().split('T')[0]}>{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </a>
        </article>
      </li>
    ))}
  </ul>

</Base>
