---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = await getCollection('categories', ({ data }) => data.scope === 'blog' || data.scope === 'both');
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);

  return categories.map(cat => ({
    params: { slug: cat.id },
    props: {
      category: cat,
      posts: allPosts
        .filter(p => p.data.category === cat.id)
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { category, posts } = Astro.props;
const categories = await getCollection('categories', ({ data }) => data.scope === 'blog' || data.scope === 'both');

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

function formatAuthor(slug: string): string {
  return slug.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
}
---
<Base title={`${category.data.title} — Blog`} description={category.data.description} fullWidth>

  <div class="blog-hero">
    <div class="wide-wrap">
      <span class="eyebrow">{category.data.title}</span>
      <h1>How we think about <em>building</em></h1>
      <p class="blog-hero-sub">{category.data.description}</p>
    </div>
  </div>

  <div class="blog-categories">
    <div class="wide-wrap">
      <a href="/blog">All</a>
      {categories.map(cat => (
        <a href={`/blog/category/${cat.id}`} class={cat.id === category.id ? 'active' : ''}>{cat.data.title}</a>
      ))}
    </div>
  </div>

  <div class="blog-index">
    <div class="wide-wrap">
      <div class="blog-grid">
        {posts.map(post => (
          <article class="blog-card">
            <div class="blog-card-body">
              <span class="blog-card-category">{post.data.category}</span>
              <h3 class="blog-card-title">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h3>
              <p class="blog-card-desc">{post.data.description}</p>
              <div class="blog-card-footer">
                <div class="blog-card-meta">
                  <time datetime={post.data.date.toISOString().split('T')[0]}>{formatDate(post.data.date)}</time>
                  <span class="blog-card-sep">&middot;</span>
                  <span class="blog-card-author">{formatAuthor(post.data.author)}</span>
                </div>
                <a href={`/blog/${post.id}`} class="blog-card-link">Read article &rarr;</a>
              </div>
            </div>
          </article>
        ))}
      </div>

      {posts.length === 0 && <p style="color: var(--gray-400); margin-top: 2rem;">No posts in this category yet.</p>}
    </div>
  </div>

</Base>

<style>
  .blog-hero {
    background: var(--black);
    padding: 6rem 2rem 3rem;
    margin-top: -5rem;
    color: var(--white);
  }
  .blog-hero .eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    margin-bottom: 1rem;
    display: block;
  }
  .blog-hero h1 {
    font-family: var(--serif);
    font-size: 2rem;
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }
  .blog-hero h1 em {
    font-style: italic;
    color: rgba(255,255,255,0.6);
  }
  .blog-hero-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.5);
    max-width: 540px;
  }
  .blog-categories {
    border-bottom: 1px solid var(--gray-200);
    padding: 0 2rem;
  }
  .blog-categories .wide-wrap {
    display: flex;
    gap: 1.5rem;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
  .blog-categories a {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    color: var(--gray-400);
    transition: color 0.2s;
  }
  .blog-categories a:hover,
  .blog-categories a.active {
    color: var(--black);
  }
  .blog-index {
    padding: 4rem 2rem 5rem;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--gray-200);
    border: 1px solid var(--gray-200);
  }
  .blog-card {
    background: var(--white);
    display: flex;
    flex-direction: column;
  }
  .blog-card-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .blog-card-category {
    font-family: var(--mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .blog-card-title {
    font-family: var(--serif);
    font-size: 1.25rem;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }
  .blog-card-title a {
    text-decoration: none;
    color: inherit;
  }
  .blog-card-title a:hover {
    color: var(--accent);
  }
  .blog-card-desc {
    font-size: 0.875rem;
    color: var(--gray-600);
    line-height: 1.6;
    flex: 1;
  }
  .blog-card-footer {
    margin-top: auto;
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .blog-card-meta {
    font-family: var(--mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-400);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .blog-card-sep {
    color: var(--gray-300);
  }
  .blog-card-author {
    color: var(--gray-600);
  }
  .blog-card-link {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--black);
    text-decoration: none;
    border-bottom: 1px solid var(--gray-200);
    padding-bottom: 0.25rem;
    align-self: flex-start;
    transition: border-color 0.15s;
  }
  .blog-card-link:hover {
    border-color: var(--black);
  }
  @media (max-width: 900px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 580px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
