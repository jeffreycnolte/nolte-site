---
import Base from '../layouts/Base.astro';
---
<Base title="Brand Guide — Nolte" fullWidth>

  <div class="brand-guide">

    <!-- HEADER -->
    <div class="brand-hero">
      <div class="wide-wrap">
        <span class="label">LIVING STYLE GUIDE</span>
        <h1>Nolte Brand System</h1>
        <p class="brand-hero-sub">The source of truth for typography, color, spacing, and components. Updated with every change.</p>
      </div>
    </div>

    <!-- COLOR -->
    <section class="brand-section">
      <div class="wide-wrap">
        <span class="label">01</span>
        <h2 class="section-heading">Color Palette</h2>

        <div class="swatch-grid">
          <div class="swatch">
            <div class="swatch-block" style="background: var(--black);"></div>
            <span class="swatch-name">Black</span>
            <code class="swatch-value">#000000</code>
            <code class="swatch-var">--black</code>
          </div>
          <div class="swatch">
            <div class="swatch-block" style="background: var(--accent);"></div>
            <span class="swatch-name">Red Nolte</span>
            <code class="swatch-value">#D63F18</code>
            <code class="swatch-var">--accent</code>
          </div>
          <div class="swatch">
            <div class="swatch-block" style="background: var(--blue);"></div>
            <span class="swatch-name">Digital Blue</span>
            <code class="swatch-value">#0369fc</code>
            <code class="swatch-var">--blue</code>
          </div>
          <div class="swatch">
            <div class="swatch-block" style="background: var(--white); border: 1px solid var(--gray-200);"></div>
            <span class="swatch-name">Warm White</span>
            <code class="swatch-value">#fafaf8</code>
            <code class="swatch-var">--white</code>
          </div>
        </div>

        <h3>Neutrals</h3>
        <div class="swatch-grid">
          <div class="swatch">
            <div class="swatch-block" style="background: var(--gray-100); border: 1px solid var(--gray-200);"></div>
            <span class="swatch-name">Gray 100</span>
            <code class="swatch-value">#f2f1ed</code>
            <code class="swatch-var">--gray-100</code>
          </div>
          <div class="swatch">
            <div class="swatch-block" style="background: var(--gray-200);"></div>
            <span class="swatch-name">Gray 200</span>
            <code class="swatch-value">#e0ded8</code>
            <code class="swatch-var">--gray-200</code>
          </div>
          <div class="swatch">
            <div class="swatch-block" style="background: var(--gray-400);"></div>
            <span class="swatch-name">Gray 400</span>
            <code class="swatch-value">#9e9b94</code>
            <code class="swatch-var">--gray-400</code>
          </div>
          <div class="swatch">
            <div class="swatch-block" style="background: var(--gray-600);"></div>
            <span class="swatch-name">Gray 600</span>
            <code class="swatch-value">#5a5854</code>
            <code class="swatch-var">--gray-600</code>
          </div>
        </div>

        <h3>Dark Mode</h3>
        <div class="swatch-grid">
          <div class="swatch">
            <div class="swatch-block" style="background: var(--dark);"></div>
            <span class="swatch-name">Dark</span>
            <code class="swatch-value">#050505</code>
            <code class="swatch-var">--dark</code>
          </div>
          <div class="swatch">
            <div class="swatch-block" style="background: var(--dark-surface);"></div>
            <span class="swatch-name">Dark Surface</span>
            <code class="swatch-value">#0d0d0d</code>
            <code class="swatch-var">--dark-surface</code>
          </div>
          <div class="swatch">
            <div class="swatch-block" style="background: var(--dark-border);"></div>
            <span class="swatch-name">Dark Border</span>
            <code class="swatch-value">#1e1e1e</code>
            <code class="swatch-var">--dark-border</code>
          </div>
        </div>

        <h3>Gradients</h3>
        <div class="swatch-grid">
          <!-- gradient-warm removed per design review -->
          <div class="swatch">
            <div class="swatch-block" style="background: var(--gradient-dark);"></div>
            <span class="swatch-name">Dark</span>
            <code class="swatch-var">--gradient-dark</code>
          </div>
          <div class="swatch">
            <div class="swatch-block" style="background: var(--gradient-hero);"></div>
            <span class="swatch-name">Hero</span>
            <code class="swatch-var">--gradient-hero</code>
          </div>
        </div>
      </div>
    </section>

    <!-- TYPOGRAPHY -->
    <section class="brand-section brand-section-alt">
      <div class="wide-wrap">
        <span class="label">02</span>
        <h2 class="section-heading">Typography</h2>

        <div class="type-specimen">
          <div class="type-sample">
            <span class="label">HEADINGS — Instrument Serif</span>
            <p class="type-demo" style="font-family: var(--serif); font-size: 3rem; line-height: 1.1;">Predictable Software Delivery</p>
            <p class="type-demo" style="font-family: var(--serif); font-size: 2rem; line-height: 1.2;">The quick brown fox jumps over the lazy dog</p>
            <p class="type-demo" style="font-family: var(--serif); font-size: 1.25rem; font-style: italic; line-height: 1.3;">Italic emphasis for <em>key words</em> — no color mixing in headings</p>
            <code class="swatch-var">--serif: 'Instrument Serif', Georgia, serif</code>
          </div>

          <div class="type-sample">
            <span class="label">BODY — Geist</span>
            <p class="type-demo" style="font-family: var(--sans); font-size: 1.125rem; line-height: 1.7;">NolteOS turns 20 years of delivery data into predictable, fixed-price software delivery. Describe what you're building and get a delivery plan with 95% accuracy on scope, timeline, and cost. Every engagement is priced per delivery with a committed cost before work begins.</p>
            <p class="type-demo" style="font-family: var(--sans); font-size: 0.9375rem; line-height: 1.7; color: var(--gray-600);">Secondary body text at smaller size with muted color for descriptions and supporting content.</p>
            <code class="swatch-var">--sans: 'Geist', system-ui, sans-serif</code>
          </div>

          <div class="type-sample">
            <span class="label">LABELS — DM Mono</span>
            <p class="type-demo" style="font-family: var(--mono); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em;">Case Study · Healthcare · 2 Years</p>
            <p class="type-demo" style="font-family: var(--mono); font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.08em;">Get Your Delivery Plan →</p>
            <p class="type-demo" style="font-family: var(--mono); font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--accent);">Insurance · Finance · Healthcare</p>
            <code class="swatch-var">--mono: 'DM Mono', monospace</code>
          </div>
        </div>

        <h3>Type Scale</h3>
        <div class="type-scale">
          <div class="type-scale-row">
            <code>3rem / 48px</code>
            <span style="font-family: var(--serif); font-size: 3rem; line-height: 1;">Page Title</span>
          </div>
          <div class="type-scale-row">
            <code>2rem / 32px</code>
            <span style="font-family: var(--serif); font-size: 2rem; line-height: 1;">Section Heading</span>
          </div>
          <div class="type-scale-row">
            <code>1.5rem / 24px</code>
            <span style="font-family: var(--serif); font-size: 1.5rem; line-height: 1;">Card Heading</span>
          </div>
          <div class="type-scale-row">
            <code>1.125rem / 18px</code>
            <span style="font-family: var(--sans); font-size: 1.125rem; line-height: 1;">Body Large</span>
          </div>
          <div class="type-scale-row">
            <code>1rem / 16px</code>
            <span style="font-family: var(--sans); font-size: 1rem; line-height: 1;">Body</span>
          </div>
          <div class="type-scale-row">
            <code>0.75rem / 12px</code>
            <span style="font-family: var(--mono); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; line-height: 1;">Label</span>
          </div>
        </div>
      </div>
    </section>

    <!-- COMPONENTS -->
    <section class="brand-section">
      <div class="wide-wrap">
        <span class="label">03</span>
        <h2 class="section-heading">Components</h2>

        <h3>Buttons</h3>
        <div class="component-row">
          <a class="btn-hero btn-hero-primary" href="#" onclick="return false">Primary CTA</a>
          <a class="btn-hero btn-hero-secondary" href="#" onclick="return false">Secondary CTA</a>
        </div>

        <h3>Labels &amp; Pills</h3>
        <div class="component-row">
          <span class="label">Eyebrow Label</span>
          <span class="case-type">Healthcare</span>
          <span class="case-type" style="color: var(--blue); border-color: var(--blue);">Finance</span>
          <span class="case-type" style="color: var(--accent); border-color: var(--accent);">Insurance</span>
        </div>

        <h3>Cards</h3>
        <div class="component-demo-grid">
          <div class="pillar-card">
            <span class="label">01</span>
            <h3>Pillar Card</h3>
            <p>Used for process steps, features, and value propositions. Orange top border accent.</p>
          </div>
          <div class="pillar-card">
            <span class="label">02</span>
            <h3>With Content</h3>
            <p>Cards use the gray-100 background with consistent padding and the serif heading font.</p>
          </div>
        </div>

        <h3>Stats</h3>
        <div class="component-row" style="gap: 3rem;">
          <div>
            <span class="stat-value">95%</span>
            <span class="label">Forecast Accuracy</span>
          </div>
          <div>
            <span class="stat-value">20yrs</span>
            <span class="label">Delivery Data</span>
          </div>
          <div>
            <span class="stat-value">75/mo</span>
            <span class="label">Deliveries</span>
          </div>
        </div>

        <h3>Metric Cards (Dark)</h3>
        <div class="component-demo-dark">
          <div class="shot-metrics-grid" style="max-width: 500px;">
            <div class="shot-metric-card">
              <div class="shot-metric-value">95.2%</div>
              <div class="shot-metric-label">Forecast Accuracy</div>
            </div>
            <div class="shot-metric-card">
              <div class="shot-metric-value">4.8d</div>
              <div class="shot-metric-label">Avg Cycle Time</div>
            </div>
            <div class="shot-metric-card">
              <div class="shot-metric-value">47</div>
              <div class="shot-metric-label">Deliveries</div>
            </div>
            <div class="shot-metric-card">
              <div class="shot-metric-value">98%</div>
              <div class="shot-metric-label">On-Time Rate</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SPACING -->
    <section class="brand-section brand-section-alt">
      <div class="wide-wrap">
        <span class="label">04</span>
        <h2 class="section-heading">Spacing &amp; Layout</h2>

        <div class="spacing-demo">
          <div class="spacing-item">
            <div class="spacing-block" style="width: 100%; height: 0.5rem; background: var(--accent);"></div>
            <code>0.5rem / 8px</code>
            <span>Element gap</span>
          </div>
          <div class="spacing-item">
            <div class="spacing-block" style="width: 100%; height: 1rem; background: var(--accent);"></div>
            <code>1rem / 16px</code>
            <span>Card padding, small gap</span>
          </div>
          <div class="spacing-item">
            <div class="spacing-block" style="width: 100%; height: 2rem; background: var(--accent);"></div>
            <code>2rem / 32px</code>
            <span>Section padding (horizontal)</span>
          </div>
          <div class="spacing-item">
            <div class="spacing-block" style="width: 100%; height: 3rem; background: var(--accent);"></div>
            <code>3rem / 48px</code>
            <span>Content gap</span>
          </div>
          <div class="spacing-item">
            <div class="spacing-block" style="width: 100%; height: 5rem; background: var(--accent);"></div>
            <code>5rem / 80px</code>
            <span>Section spacing (vertical)</span>
          </div>
        </div>

        <h3>Layout Widths</h3>
        <div class="spacing-demo">
          <div class="spacing-item">
            <code>1100px</code>
            <span>Max content width (.wide-wrap)</span>
          </div>
          <div class="spacing-item">
            <code>780px</code>
            <span>Prose / blog content max-width</span>
          </div>
          <div class="spacing-item">
            <code>100%</code>
            <span>Full-bleed sections (hero, dark sections)</span>
          </div>
        </div>
      </div>
    </section>

    <!-- PATTERNS -->
    <section class="brand-section">
      <div class="wide-wrap">
        <span class="label">05</span>
        <h2 class="section-heading">Patterns &amp; Rules</h2>

        <div class="rules-grid">
          <div class="rule-card">
            <h3>Dark / Light Rhythm</h3>
            <p>Alternate between dark (hero, callouts, footer CTA) and light (content, cards) sections. Don't stack more than two dark sections consecutively.</p>
          </div>
          <div class="rule-card">
            <h3>Accent Usage</h3>
            <p>Red (#D63F18) for CTAs and category pills only. Headings are black or white — no color mixing. Blue used minimally for links. Stats use black uniformly.</p>
          </div>
          <div class="rule-card">
            <h3>Label Pattern</h3>
            <p>DM Mono, uppercase, letter-spacing 0.08–0.12em, font-size 0.6875–0.75rem. Used for eyebrows, metadata, nav links, and category tags.</p>
          </div>
          <div class="rule-card">
            <h3>Card Borders</h3>
            <p>Use 2px solid orange top-border on process/step cards. Use 1px gray-200 border on content cards. No rounded corners — sharp edges throughout.</p>
          </div>
          <div class="rule-card">
            <h3>Imagery</h3>
            <p>Real product screenshots in device frames. Team photography (not stock). Abstract geometric visuals for blog posts. No generic stock photos.</p>
          </div>
          <div class="rule-card">
            <h3>Voice in Design</h3>
            <p>Direct, confident, data-driven. Lead with numbers. Use "predictable delivery" not "agile." Say "leaders who outsource" not "non-tech founders."</p>
          </div>
        </div>
      </div>
    </section>

  </div>

</Base>

<style>
  .brand-guide { padding-bottom: 5rem; }

  .brand-hero {
    background: var(--dark);
    color: var(--white);
    padding: 6rem 2rem 4rem;
  }
  .brand-hero h1 { font-family: var(--serif); font-size: 3rem; margin: 1rem 0 0.75rem; }
  .brand-hero-sub { color: var(--gray-400); font-size: 1.0625rem; max-width: 540px; }

  .brand-section { padding: 4rem 2rem; }
  .brand-section-alt { background: var(--gray-100); }
  .brand-section h3 { font-family: var(--serif); font-size: 1.5rem; margin: 3rem 0 1.5rem; }

  /* Swatches */
  .swatch-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin: 1.5rem 0; }
  .swatch-block { width: 100%; aspect-ratio: 1.6; border-radius: 4px; }
  .swatch-name { display: block; font-family: var(--sans); font-weight: 500; font-size: 0.9375rem; margin-top: 0.75rem; }
  .swatch-value { display: block; font-family: var(--mono); font-size: 0.75rem; color: var(--gray-600); margin-top: 0.25rem; }
  .swatch-var { display: block; font-family: var(--mono); font-size: 0.6875rem; color: var(--gray-400); margin-top: 0.125rem; }

  /* Type specimens */
  .type-specimen { display: flex; flex-direction: column; gap: 3rem; margin: 1.5rem 0; }
  .type-sample { border-left: 2px solid var(--accent); padding-left: 2rem; }
  .type-demo { margin: 0.75rem 0; }

  /* Type scale */
  .type-scale { display: flex; flex-direction: column; gap: 1rem; margin: 1.5rem 0; }
  .type-scale-row {
    display: flex; align-items: baseline; gap: 2rem;
    padding: 0.75rem 0; border-bottom: 1px solid var(--gray-200);
  }
  .type-scale-row code { font-family: var(--mono); font-size: 0.6875rem; color: var(--gray-400); min-width: 120px; }

  /* Components */
  .component-row { display: flex; align-items: center; flex-wrap: wrap; gap: 1.5rem; margin: 1.5rem 0; }
  .component-demo-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin: 1.5rem 0; max-width: 700px; }
  .component-demo-dark { background: var(--dark); padding: 2rem; border-radius: 4px; margin: 1.5rem 0; }

  /* Spacing */
  .spacing-demo { display: flex; flex-direction: column; gap: 1rem; margin: 1.5rem 0; }
  .spacing-item { display: flex; align-items: center; gap: 1.5rem; }
  .spacing-item code { font-family: var(--mono); font-size: 0.75rem; color: var(--gray-600); min-width: 100px; }
  .spacing-item span { font-size: 0.9375rem; color: var(--gray-600); }
  .spacing-block { flex-shrink: 0; max-width: 200px; }

  /* Rules grid */
  .rules-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin: 1.5rem 0; }
  .rule-card { background: var(--gray-100); padding: 1.5rem; border-top: 2px solid var(--accent); }
  .rule-card h3 { font-family: var(--serif); font-size: 1.125rem; margin: 0 0 0.75rem; }
  .rule-card p { font-size: 0.9375rem; color: var(--gray-600); line-height: 1.6; }

  @media (max-width: 768px) {
    .swatch-grid { grid-template-columns: repeat(2, 1fr); }
    .component-demo-grid { grid-template-columns: 1fr; }
    .rules-grid { grid-template-columns: 1fr; }
    .type-scale-row { flex-direction: column; gap: 0.5rem; }
    .brand-hero h1 { font-size: 2rem; }
  }
</style>
