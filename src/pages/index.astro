            <rect x="118" y="42" width="54" height="6" rx="3" fill="rgba(3,105,252,0.3)" />
            <rect x="118" y="54" width="54" height="6" rx="3" fill="rgba(3,105,252,0.25)" />
            <rect x="118" y="66" width="54" height="6" rx="3" fill="rgba(3,105,252,0.2)" />
