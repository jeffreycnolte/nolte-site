---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<Base title="Predictable Software Delivery" fullWidth>

  <!-- DARK HERO -->
  <div class="hero-dark hero-centered">
    <div class="wide-wrap">
      <h1>Predictable Software<br>Delivery for Leaders<br>Who Can't Afford to <em>Miss</em></h1>
      <p class="hero-subtext">NolteOS turns 20 years of delivery data into predictable, fixed-price software delivery. Describe what you're building and get a delivery plan with 95% accuracy on scope, timeline, and cost.</p>
      <div class="hero-actions">
        <a class="btn-hero btn-hero-primary" href="https://os.nolte.io">See Your Forecast</a>
        <a class="btn-hero btn-hero-secondary" href="/blog/the-predictability-gap">Read The Predictability Gap</a>
      </div>
    </div>
  </div>

  <!-- PILLARS -->
  <div class="pillars">
    <div class="pillars-grid">
      <div class="pillar">
        <span class="pillar-label">Delivery</span>
        <h3>Guaranteed Delivery</h3>
        <p>Fixed price per delivery. You only pay for what we ship. Our incentives are structurally aligned with yours.</p>
      </div>
      <div class="pillar">
        <span class="pillar-label">Accuracy</span>
        <h3>95% Prediction Accuracy</h3>
        <p>NolteOS uses three years of flow data to forecast delivery. No estimates, no guesswork, no surprises.</p>
      </div>
      <div class="pillar">
        <span class="pillar-label">Experience</span>
        <h3>Founders Who've Exited</h3>
        <p>We've built companies from zero, scaled them, and sold them. That experience shapes every decision we make.</p>
      </div>
      <div class="pillar">
        <span class="pillar-label">Model</span>
        <h3>Efficiency Over Activity</h3>
        <p>We measure outcomes delivered, not hours billed. When your interests come first, speed becomes profitable.</p>
      </div>
    </div>
  </div>

  <!-- TRUST LOGOS -->
  <div class="trust-bar trust-bar-light">
    <p class="trust-label">Trusted partners</p>
    <div class="trust-logos">
      <img src="/images/logos/hbo.png" alt="HBO" class="trust-logo-img" />
      <img src="/images/logos/amtrak.png" alt="Amtrak" class="trust-logo-img" />
      <img src="/images/logos/odie.png" alt="Odie" class="trust-logo-img" />
      <img src="/images/logos/barrys.png" alt="Barry's" class="trust-logo-img" />
      <img src="/images/logos/bloomscape.png" alt="Bloomscape" class="trust-logo-img" />
      <img src="/images/logos/footprint.png" alt="Footprint" class="trust-logo-img" />
    </div>
  </div>

  <!-- HUMAN: WHO WE ARE -->
  <div class="human-section">
    <div class="human-row">
      <div class="human-photo">
        <!-- IMAGE NEEDED: Team photo or Jeffrey portrait, warm/authentic, not stock -->
        <div class="human-photo-placeholder">
          <span class="placeholder-label">Team Photo</span>
        </div>
      </div>
      <div class="human-content">
        <h2>We've been in your seat</h2>
        <p>Nolte was founded by operators who've built companies from zero, scaled them, and sold them. We know what it feels like to approve a six-figure software engagement and hope it works out. That's why we built a system that removes hope from the equation.</p>
        <p>We're a distributed team across the Americas — designers, engineers, and product strategists who measure success by what ships, not what's billed.</p>
        <a class="human-link" href="/about">Learn about our story &rarr;</a>
      </div>
    </div>
  </div>

  <!-- DELIVERY PERFORMANCE -->
  <div class="delivery-performance">
    <div class="wide-wrap">
      <div class="delivery-perf-content">
        <div class="delivery-perf-text">
          <span class="eyebrow">Live Delivery Data</span>
          <h2>Week over week performance</h2>
          <p>Real delivery metrics from active engagements. Not vanity numbers — the same data our clients see in NolteOS.</p>
          <div class="delivery-perf-stats">
            <div class="dp-stat">
              <span class="dp-stat-value">95%</span>
              <span class="dp-stat-label">Forecast Accuracy</span>
            </div>
            <div class="dp-stat">
              <span class="dp-stat-value">75/mo</span>
              <span class="dp-stat-label">Deliveries Shipped</span>
            </div>
            <div class="dp-stat">
              <span class="dp-stat-value">4.8d</span>
              <span class="dp-stat-label">Avg Cycle Time</span>
            </div>
            <div class="dp-stat">
              <span class="dp-stat-value">20yrs</span>
              <span class="dp-stat-label">Delivery Data</span>
            </div>
          </div>
        </div>
        <div class="delivery-perf-chart">
          <div class="shot-window shot-window-dark">
            <div class="shot-toolbar">
              <span class="shot-dot"></span><span class="shot-dot"></span><span class="shot-dot"></span>
            </div>
            <div class="shot-content" style="padding: 1.5rem;">
              <div class="perf-chart-header">
                <span class="perf-chart-title">Weekly Deliveries</span>
                <span class="perf-chart-range">Last 8 Weeks</span>
              </div>
              <div class="perf-chart-bars">
                <div class="perf-bar-group">
                  <div class="perf-bar" style="height: 65%;"><span class="perf-bar-val">14</span></div>
                  <span class="perf-bar-label">W1</span>
                </div>
                <div class="perf-bar-group">
                  <div class="perf-bar" style="height: 78%;"><span class="perf-bar-val">17</span></div>
                  <span class="perf-bar-label">W2</span>
                </div>
                <div class="perf-bar-group">
                  <div class="perf-bar" style="height: 72%;"><span class="perf-bar-val">16</span></div>
                  <span class="perf-bar-label">W3</span>
                </div>
                <div class="perf-bar-group">
                  <div class="perf-bar" style="height: 85%;"><span class="perf-bar-val">19</span></div>
                  <span class="perf-bar-label">W4</span>
                </div>
                <div class="perf-bar-group">
                  <div class="perf-bar" style="height: 70%;"><span class="perf-bar-val">15</span></div>
                  <span class="perf-bar-label">W5</span>
                </div>
                <div class="perf-bar-group">
                  <div class="perf-bar" style="height: 82%;"><span class="perf-bar-val">18</span></div>
                  <span class="perf-bar-label">W6</span>
                </div>
                <div class="perf-bar-group">
                  <div class="perf-bar" style="height: 90%;"><span class="perf-bar-val">20</span></div>
                  <span class="perf-bar-label">W7</span>
                </div>
                <div class="perf-bar-group">
                  <div class="perf-bar perf-bar-current" style="height: 80%;"><span class="perf-bar-val">18</span></div>
                  <span class="perf-bar-label">W8</span>
                </div>
              </div>
              <div class="perf-chart-footer">
                <span>Deployments: 142</span>
                <span>On-time: 97%</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- THE PREDICTABILITY GAP -->
  <div class="featured-block featured-block-wide">
    <div class="featured-inner-split">
      <div class="featured-text">
        <span class="featured-tag">Featured</span>
        <h2>The Predictability Gap</h2>
        <p>Every business function forecasts in order to be predictable. Software development does neither. It's the only function on the P&L where leadership approves spend without knowing what will be delivered, when, or what it will cost.</p>
        <a class="featured-link" href="/blog/the-predictability-gap">Read the full article &rarr;</a>
      </div>
      <div class="featured-visual">
        <!-- IMAGE NEEDED: Abstract visualization or editorial image representing the gap between estimation and forecasting -->
        <div class="featured-visual-placeholder">
          <svg viewBox="0 0 280 200" xmlns="http://www.w3.org/2000/svg">
            <rect x="20" y="30" width="100" height="140" rx="4" fill="rgba(0,0,0,0.03)" stroke="rgba(0,0,0,0.08)" stroke-width="1" />
            <rect x="160" y="30" width="100" height="140" rx="4" fill="rgba(214,63,24,0.04)" stroke="rgba(214,63,24,0.12)" stroke-width="1" />
            <rect x="30" y="50" width="80" height="5" rx="2.5" fill="rgba(0,0,0,0.08)" />
            <rect x="30" y="65" width="60" height="5" rx="2.5" fill="rgba(0,0,0,0.06)" />
            <rect x="30" y="80" width="70" height="5" rx="2.5" fill="rgba(0,0,0,0.05)" />
            <rect x="30" y="95" width="50" height="5" rx="2.5" fill="rgba(0,0,0,0.04)" />
            <rect x="170" y="50" width="80" height="5" rx="2.5" fill="rgba(214,63,24,0.2)" />
            <rect x="170" y="65" width="80" height="5" rx="2.5" fill="rgba(214,63,24,0.18)" />
            <rect x="170" y="80" width="80" height="5" rx="2.5" fill="rgba(214,63,24,0.15)" />
            <rect x="170" y="95" width="80" height="5" rx="2.5" fill="rgba(214,63,24,0.12)" />
            <text x="70" y="145" font-size="9" fill="rgba(0,0,0,0.25)" font-family="monospace" text-anchor="middle">estimate</text>
            <text x="210" y="145" font-size="9" fill="rgba(214,63,24,0.5)" font-family="monospace" text-anchor="middle">forecast</text>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- HOW PREDICTIVE DELIVERY WORKS -->
  <div class="how-it-works">
    <div class="wide-wrap">
      <h2 class="section-heading">How Predictive Delivery Works</h2>
      <p class="section-sub">Scope. Timeline. Cost. Guaranteed before you commit.</p>
    </div>
    <div class="steps-grid">
      <div class="step-cell">
        <div class="step-num">1</div>
        <h3>Scope</h3>
        <span class="step-subtitle">Describe what you're building</span>
        <p>Tell us what you need. We break it into discrete, measurable deliveries — each with a clear definition of done and a fixed price.</p>
        <div class="step-visual">
          <span class="sv-key">input</span> &rarr; <span class="sv-val">what you're building</span><br>
          <span class="sv-key">output</span> &rarr; <span class="sv-val">scoped deliveries</span><br>
          <span class="sv-key">each</span> &rarr; <span class="sv-val">definition of done + price</span>
        </div>
      </div>
      <div class="step-cell">
        <div class="step-num">2</div>
        <h3>Timeline</h3>
        <span class="step-subtitle">NolteOS forecasts your build</span>
        <p>Our delivery engine uses 20 years of flow data to predict exactly when each delivery lands. 95% accuracy — not an estimate, a forecast.</p>
        <div class="step-visual">
          <span class="sv-key">accuracy</span> &rarr; <span class="sv-val">95.2%</span><br>
          <span class="sv-key">delivery</span> &rarr; <span class="sv-val">Week 8</span><br>
          <span class="sv-key">confidence</span> &rarr; <span class="sv-val">Monte Carlo</span>
        </div>
      </div>
      <div class="step-cell">
        <div class="step-num">3</div>
        <h3>Cost</h3>
        <span class="step-subtitle">Fixed price per delivery</span>
        <p>You pay for what ships. If it doesn't ship, you don't pay. The price is committed before work begins. We carry the risk.</p>
        <div class="step-visual">
          <span class="sv-key">price</span> &rarr; <span class="sv-val">fixed per delivery</span><br>
          <span class="sv-key">billing</span> &rarr; <span class="sv-val">zero hourly</span><br>
          <span class="sv-key">risk</span> &rarr; <span class="sv-val">we carry it</span>
        </div>
      </div>
    </div>
    <div class="steps-cta">
      <p class="steps-cta-text">A <strong>delivery</strong> is a discrete, measurable unit of work with a clear definition of done. Every delivery has a forecasted timeline and a fixed price — before work begins.</p>
      <a class="btn-accent" href="https://os.nolte.io">See it in action — predict your delivery in 30 seconds &rarr;</a>
    </div>
  </div>

  <!-- NOLTEOS CALLOUT -->
  <div class="nolteos-callout">
    <div class="nolteos-callout-inner">
      <div class="nolteos-callout-content">
        <div class="os-tag">NolteOS <span class="live-dot"></span></div>
        <h2>The predictability engine behind every delivery</h2>
        <p>NolteOS uses 20 years of delivery data to forecast scope, timeline, and cost before work begins. It's how we price per delivery, not per hour — and how our clients know exactly what they're getting before they commit.</p>
        <ul class="nolteos-callout-features">
          <li>95% forecast accuracy across all engagements</li>
          <li>Real-time delivery tracking and metrics</li>
          <li>Transparent scope, timeline, and cost visibility</li>
        </ul>
        <a class="nolteos-callout-link" href="https://os.nolte.io">See Your Forecast &rarr;</a>
      </div>
      <div class="nolteos-callout-preview">
        <div class="shot-window shot-window-dark">
          <div class="shot-toolbar">
            <span class="shot-dot"></span><span class="shot-dot"></span><span class="shot-dot"></span>
          </div>
          <div class="shot-content">
            <div class="nolteos-mini-metrics">
              <div class="nolteos-mini-metric">
                <span class="nolteos-mini-label">Forecast Accuracy</span>
                <span class="nolteos-mini-value">95.2%</span>
              </div>
              <div class="nolteos-mini-metric">
                <span class="nolteos-mini-label">Cycle Time</span>
                <span class="nolteos-mini-value">4.8d</span>
              </div>
              <div class="nolteos-mini-metric">
                <span class="nolteos-mini-label">Weekly Throughput</span>
                <span class="nolteos-mini-value">18</span>
              </div>
              <div class="nolteos-mini-metric">
                <span class="nolteos-mini-label">On-Time Rate</span>
                <span class="nolteos-mini-value">97%</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- CASE STUDIES -->
  <div class="case-studies">
    <h2 class="section-heading">Trusted partnerships</h2>
    <p class="section-sub">Teams building critical software we've taken from vision to production. Predictably.</p>

    <div class="case-grid">
      <div class="case-card">
        <div class="case-card-top">
          <span class="case-card-logo-text">Breeze</span>
          <div class="case-card-metrics">
            <span class="case-metric">47 <span class="case-metric-label">deliveries</span></span>
            <span class="case-metric">100% <span class="case-metric-label">accuracy</span></span>
          </div>
        </div>
        <div class="case-card-body">
          <div class="case-card-meta-line">
            <span class="case-pill">Healthcare</span>
            <span class="case-stage">Series A</span>
          </div>
          <h3>Breeze Oral Care</h3>
          <p class="case-desc">HIPAA-compliant dental platform. Discovery to launch in four months. On time, on budget, to the dollar.</p>
          <div class="case-meta">
            <div class="case-meta-item"><span class="case-meta-value">2 years</span><span class="case-meta-label">Partnership</span></div>
            <div class="case-meta-item"><span class="case-meta-value">HIPAA</span><span class="case-meta-label">Compliance</span></div>
          </div>
          <a class="case-link" href="/work/breeze-oral-care">Read Case Study</a>
        </div>
      </div>
      <div class="case-card">
        <div class="case-card-top">
          <span class="case-card-logo-text">Pilou</span>
          <div class="case-card-metrics">
            <span class="case-metric">85 <span class="case-metric-label">deliveries</span></span>
            <span class="case-metric">96% <span class="case-metric-label">accuracy</span></span>
          </div>
        </div>
        <div class="case-card-body">
          <div class="case-card-meta-line">
            <span class="case-pill">Finance</span>
            <span class="case-stage">Series B</span>
          </div>
          <h3>Pilou</h3>
          <p class="case-desc">Financial services platform built under regulatory and compliance requirements. Full audit trail visibility from day one.</p>
          <div class="case-meta">
            <div class="case-meta-item"><span class="case-meta-value">2 years</span><span class="case-meta-label">Partnership</span></div>
            <div class="case-meta-item"><span class="case-meta-value">KYC/AML</span><span class="case-meta-label">Compliance</span></div>
          </div>
          <a class="case-link" href="/work/pilou">Read Case Study</a>
        </div>
      </div>
      <div class="case-card">
        <div class="case-card-top">
          <span class="case-card-logo-text">Odie</span>
          <div class="case-card-metrics">
            <span class="case-metric">120 <span class="case-metric-label">deliveries</span></span>
            <span class="case-metric">95% <span class="case-metric-label">accuracy</span></span>
          </div>
        </div>
        <div class="case-card-body">
          <div class="case-card-meta-line">
            <span class="case-pill">Insurance</span>
            <span class="case-stage">Series A &mdash; Pet Insurance MGA</span>
          </div>
          <h3>Odie</h3>
          <p class="case-desc">Insurance platform built from zero under carrier requirements and state regulatory obligations. Thousands of active policyholders.</p>
          <div class="case-meta">
            <div class="case-meta-item"><span class="case-meta-value">3 years</span><span class="case-meta-label">Partnership</span></div>
            <div class="case-meta-item"><span class="case-meta-value">State Reg</span><span class="case-meta-label">Compliance</span></div>
          </div>
          <a class="case-link" href="/work/odie">Read Case Study</a>
        </div>
      </div>
    </div>
  </div>

  <!-- VERTICALS -->
  <div class="verticals">
    <h2 class="section-heading">Where we deliver</h2>
    <p class="section-sub">Industries where software delivery has to be predictable — because the cost of getting it wrong is too high.</p>

    <div class="verticals-grid">
      <a class="vertical-cell vertical-cell-link" href="/industries/insurance">
        <h3>Insurance</h3>
        <ul class="vertical-items">
          <li>State filing deadlines that don't move</li>
          <li>Carrier and MGA platform builds under regulatory scrutiny</li>
          <li>Legacy modernization at enterprise scale</li>
          <li>Claims processing that must work on day one</li>
        </ul>
        <span class="vertical-cta">See our insurance practice &rarr;</span>
      </a>
      <a class="vertical-cell vertical-cell-link" href="/industries/healthcare">
        <h3>Healthcare</h3>
        <ul class="vertical-items">
          <li>HIPAA compliance from day one, not retrofitted</li>
          <li>Patient-facing products that can't ship late</li>
          <li>Clinical workflow integrations with zero downtime</li>
          <li>Regulatory deadlines set by agencies, not product teams</li>
        </ul>
        <span class="vertical-cta">See our healthcare practice &rarr;</span>
      </a>
      <a class="vertical-cell vertical-cell-link" href="/industries/finance">
        <h3>Finance</h3>
        <ul class="vertical-items">
          <li>Regulatory compliance built into every delivery</li>
          <li>Audit trail visibility from day one</li>
          <li>Real-time platforms with multi-system dependencies</li>
          <li>Data handling that meets financial industry standards</li>
        </ul>
        <span class="vertical-cta">See our finance practice &rarr;</span>
      </a>
    </div>
  </div>

  <!-- TESTIMONIAL -->
  <div class="testimonial-featured">
    <div class="testimonial-featured-inner">
      <div class="testimonial-featured-logo">
        <!-- IMAGE NEEDED: Breeze logo -->
        <span class="testimonial-brand-name">Breeze</span>
      </div>
      <blockquote>"They can build anything and do so beautifully and on time. They have also helped me tremendously in thinking strategically, even if it means I'm paying them less in the short term."</blockquote>
      <div class="testimonial-featured-author">
        <img src="/images/work/breeze/josh.jpg" alt="Dr. Josh Turnbull" class="testimonial-avatar-img" />
        <div class="testimonial-info">
          <span class="testimonial-name">Dr. Josh Turnbull</span>
          <span class="testimonial-role">CEO, Breeze Oral Care</span>
        </div>
      </div>
    </div>
  </div>

  <!-- INNOVATION -->
  <div class="innovation-section">
    <h2 class="section-heading">Predictable <em>innovation</em></h2>
    <p class="section-sub">We bring startup velocity and innovation to scaling companies — with the predictability and accountability they need.</p>
    <div class="innovation-grid">
      <div class="innovation-card">
        <span class="innovation-card-number">01</span>
        <h3>Startup Experience, Enterprise Accountability</h3>
        <p>Our team has built, scaled, and sold companies. We apply that speed and resourcefulness to later-stage companies where internal innovation has stalled.</p>
      </div>
      <div class="innovation-card">
        <span class="innovation-card-number">02</span>
        <h3>AI-Augmented, Forecast-Driven</h3>
        <p>We use AI to accelerate development while NolteOS ensures every delivery stays on forecast. Faster code, same predictability.</p>
      </div>
      <div class="innovation-card">
        <span class="innovation-card-number">03</span>
        <h3>Plug-and-Play Delivery Teams</h3>
        <p>Cross-functional teams that embed with your org, deliver immediately, and scale with your roadmap. No ramp-up period. No hand-holding.</p>
      </div>
    </div>
  </div>

  <!-- BLOG POSTS -->
  <div class="blog-featured">
    <div class="blog-featured-header">
      <div>
        <h2 class="section-heading">From the blog</h2>
        <p class="section-sub">How we think about software delivery, forecasting, and building products that ship.</p>
      </div>
      <a class="blog-index-link" href="/blog">View all posts &rarr;</a>
    </div>

    <div class="blog-featured-grid">
      {posts.map(post => (
        <a class="blog-featured-card" href={`/blog/${post.id}`}>
          {post.data.image && <img src={post.data.image} alt={post.data.imageAlt || post.data.title} class="blog-featured-img" />}
          <div class="blog-featured-card-body">
            <span class="blog-featured-category">{post.data.category}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="blog-featured-read">Read article &rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- GLOBAL PREDICTABILITY CTA -->
  <div class="predictability-cta">
    <div class="predictability-cta-inner">
      <div class="predictability-cta-content">
        <h2>See what predictable delivery looks like.</h2>
        <p>Describe what you're building. NolteOS forecasts the scope, timeline, and cost — before you commit.</p>
        <a class="btn-accent" href="https://os.nolte.io">See Your Forecast</a>
      </div>
      <div class="predictability-cta-visual">
        <!-- IMAGE NEEDED: NolteOS dashboard screenshot or abstract delivery visualization -->
        <div class="shot-window shot-window-dark" style="max-width: 380px;">
          <div class="shot-toolbar">
            <span class="shot-dot"></span><span class="shot-dot"></span><span class="shot-dot"></span>
          </div>
          <div class="shot-content" style="padding: 1.25rem;">
            <div style="font-family: var(--mono); font-size: 10px; color: rgba(255,255,255,0.3); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1rem;">Your Forecast</div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
              <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); padding: 0.75rem;">
                <div style="font-family: var(--mono); font-size: 9px; color: rgba(255,255,255,0.3); text-transform: uppercase; letter-spacing: 0.06em;">Deliveries</div>
