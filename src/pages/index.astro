---
import Base from '../layouts/Base.astro';
import CaseCard from '../components/CaseCard.astro';
import CtaSection from '../components/CtaSection.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const caseLogos: Record<string, { src: string; height: string }> = {
  'breeze-oral-care':  { src: '/images/logos/breeze.svg',  height: '20px' },
  'pilou':             { src: '/images/logos/pilou.png',   height: '22px' },
  'odie':              { src: '/images/logos/odie.png',    height: '24px' },
  'wake':              { src: '/images/logos/wake.png',    height: '20px' },
  'barrys-bootcamp':   { src: '/images/logos/barrys.png',  height: '18px' },
  'klipster':          { src: '/images/logos/klipster.png', height: '18px' },
  'morphus':           { src: '/images/logos/morphus.svg',  height: '14px' },
  'squadup':           { src: '/images/logos/squadup.svg',  height: '22px' },
};
---
<Base title="Innovate Predictably — Nolte" description="We evolve ambitious ideas into shipped products — when getting it wrong is not an option. Senior operators shape the thinking. NolteOS and a predictive delivery system guarantee the build." fullWidth>

  <!-- ═══════════════════════════════════════════
       1. HERO — The bet we derisk + for whom
       ═══════════════════════════════════════════ -->
  <div class="hero-dark hero-centered">
    <div class="wide-wrap hero-editorial">
      <span class="hero-eyebrow">Innovate Predictably</span>
      <h1>We evolve ambitious ideas into shipped products — when getting it wrong is not an <em>option</em></h1>
      <p class="hero-subtext hero-subtext-centered">Nolte is a consultative product partner for regulated industries. We put senior operators in the room to shape the thinking, then use NolteOS and a predictive delivery system to guarantee the build.</p>
      <div class="hero-actions hero-actions-centered">
        <a class="btn-hero btn-hero-primary" href="https://os.nolte.io">Build Your Product Roadmap &rarr;</a>
        <a class="btn-hero btn-hero-secondary" href="/contact">Let's Talk</a>
      </div>
      <p class="hero-micro hero-micro-centered">Build your product roadmap in under 60 seconds. We surface the risks, the opportunities, and the competitive landscape.</p>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       2. PROOF STRIP — Fast credibility
       ═══════════════════════════════════════════ -->
  <div class="proof-strip">
    <div class="proof-items">
      <div class="proof-item">
        <span class="proof-value">20 years</span>
        <span class="proof-label">Delivery data</span>
      </div>
      <div class="proof-divider"></div>
      <div class="proof-item">
        <span class="proof-value">Zero → Exit</span>
        <span class="proof-label">Operator experience</span>
      </div>
      <div class="proof-divider"></div>
      <div class="proof-item">
        <span class="proof-value">95%</span>
        <span class="proof-label">Forecast accuracy</span>
      </div>
      <div class="proof-divider"></div>
      <div class="proof-item">
        <span class="proof-value">15</span>
        <span class="proof-label">0→1 Cos Launched</span>
      </div>
    </div>
  </div>

  <!-- TRUST LOGOS -->
  <div class="trust-bar trust-bar-light">
    <p class="trust-label">Products we've shaped and shipped</p>
    <div class="trust-logos">
      <img src="/images/logos/pilou.png" alt="Pilou" class="trust-logo-img" style="height:19px" />
      <img src="/images/logos/odie.png" alt="Odie" class="trust-logo-img" style="height:22px" />
      <img src="/images/logos/securecpg.svg" alt="Secure CPG" class="trust-logo-img" style="height:22px" />
      <img src="/images/logos/barrys.png" alt="Barry's" class="trust-logo-img" style="height:17px" />
      <img src="/images/logos/breeze.svg" alt="Breeze" class="trust-logo-img" style="height:22px" />
      <img src="/images/logos/hbo.png" alt="HBO" class="trust-logo-img" style="height:22px" />
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       3. WHAT WE DO — Consultative → Execution arc
       ═══════════════════════════════════════════ -->
  <div class="build-modes">
    <div class="wide-wrap">
      <span class="eyebrow" style="color: var(--accent);">What We Do</span>
      <h2 class="section-heading">The consultative depth most firms skip — backed by a delivery <em>guarantee</em></h2>
      <p class="section-sub">We don't start by writing code. We start by figuring out if the thing should be built, how it should be shaped, and what it takes to survive the regulatory environment.</p>
    </div>
    <div class="build-modes-grid">
      <div class="build-mode">
        <span class="build-mode-num">01</span>
        <h3>Shape the Thinking</h3>
        <p class="build-mode-lead">We figure out whether and how something should be built.</p>
        <p>Market analysis, competitive positioning, product architecture, regulatory navigation, business model pressure-testing. Senior operators do the thinking before a line of code gets written. That's not a phase we rush through — it's the most valuable thing we do.</p>
      </div>
      <div class="build-mode">
        <span class="build-mode-num">02</span>
        <h3>Build the Product</h3>
        <p class="build-mode-lead">NolteOS translates strategic decisions into shipped product.</p>
        <p>The senior operator figures out the right thing to build. NolteOS and our delivery system handle the execution layer — faster, more consistently, and more aligned to the original intent than a chain of handoffs ever could. The strategic layer is human judgment. The execution layer is systematized.</p>
      </div>
      <div class="build-mode">
        <span class="build-mode-num">03</span>
        <h3>Guarantee the Delivery</h3>
        <p class="build-mode-lead">Fixed price per delivery. If it doesn't ship, you don't pay.</p>
        <p>NolteOS uses 20 years of experience and historic delivery data to predict scope, timeline, and cost before work begins. 95% forecast accuracy. Per-delivery pricing means we carry the execution risk — which means we're economically motivated to get the strategy right.</p>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       4. WHY NOLTE — Judgment, operators, "not yes people"
       ═══════════════════════════════════════════ -->
  <div class="human-section">
    <div class="human-row">
      <div class="human-photo">
        <span class="eyebrow">Founders &amp; Leadership</span>
        <div class="founders-row">
          <div class="founder">
            <img src="/images/team/jeffrey-nolte-web.png" alt="Jeffrey Nolte" class="founder-img" loading="lazy" />
            <span class="founder-name">Jeffrey Nolte <a href="https://www.linkedin.com/in/jeffreynolte/" target="_blank" rel="noopener" class="founder-linkedin" aria-label="Jeffrey Nolte on LinkedIn"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a></span>
            <span class="founder-role">Managing Director</span>
            <span class="founder-exits">2x Exits</span>
            <span class="founder-bio">20 years building and scaling product companies in regulated industries.</span>
          </div>
          <div class="founder">
            <div class="founder-img-wrap"><img src="/images/team/yanna-lopes-web.jpg" alt="Yanna Lopes" loading="lazy" /></div>
            <span class="founder-name">Yanna Lopes <a href="https://www.linkedin.com/in/yannalopes/" target="_blank" rel="noopener" class="founder-linkedin" aria-label="Yanna Lopes on LinkedIn"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a></span>
            <span class="founder-role">Head of Products</span>
            <span class="founder-exits">1x Exit</span>
            <span class="founder-bio">Legal background turned product leader. Shapes strategy and holds the line on quality.</span>
          </div>
        </div>
      </div>
      <div class="human-content">
        <h2>We're not yes people</h2>
        <p>We've built companies, navigated boards, made payroll, and sold businesses. When we tell you something won't work, it's because we've been the founder who learned that the hard way — with our own money on the line.</p>
        <p>We challenge product theses. We flag risks. We change the whole direction if needed. We often say no if the risk is too high and we can't build toward long-term success or partnership. A dev shop takes the money. We protect the founder from a bad bet.</p>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       5. DELIVERY GUARANTEE — Dark proof band
       ═══════════════════════════════════════════ -->
  <div class="guarantee-section">
    <div class="guarantee-inner">
      <div class="guarantee-text">
        <span class="guarantee-eyebrow">The Delivery Guarantee</span>
        <h2>Predictability is our methodology,<br>not our pitch.</h2>
        <p>Every firm promises to deliver. We back ours with a system: NolteOS uses 20 years of experience and historic delivery data to predict scope, timeline, and cost before work begins. Fixed price per delivery. If it doesn't ship, you don't pay. The pricing model puts our revenue on the line — which is why we invest so heavily in getting the strategy right first.</p>
        <div class="guarantee-metrics">
          <div class="guarantee-metric">
            <span class="guarantee-metric-val">95%</span>
            <span class="guarantee-metric-label">Prediction Accuracy</span>
          </div>
          <div class="guarantee-metric">
            <span class="guarantee-metric-val">75/mo</span>
            <span class="guarantee-metric-label">Deliveries Shipped</span>
          </div>
          <div class="guarantee-metric">
            <span class="guarantee-metric-val">4.8d</span>
            <span class="guarantee-metric-label">Avg Cycle Time</span>
          </div>
          <div class="guarantee-metric">
            <span class="guarantee-metric-val">97%</span>
            <span class="guarantee-metric-label">On-Time Rate</span>
          </div>
        </div>
      </div>
      <div class="guarantee-visual">
        <div class="os-preview">
          <div class="os-section-label">NolteOS — Delivery Forecast</div>
          <div class="os-roadmap">
            <div class="os-roadmap-header">
              <div class="os-roadmap-col">Phase</div>
              <div class="os-roadmap-months"><span>Apr</span><span>May</span><span>Jun</span><span>Jul</span></div>
            </div>
            <div class="os-roadmap-row">
              <div class="os-roadmap-label">Strategy<div class="os-roadmap-meta">10 deliveries</div></div>
              <div class="os-roadmap-track"><div class="os-roadmap-bar os-bar-strategy" style="width:25%;left:0"></div></div>
            </div>
            <div class="os-roadmap-row">
              <div class="os-roadmap-label">Build<div class="os-roadmap-meta">52 deliveries</div></div>
              <div class="os-roadmap-track"><div class="os-roadmap-bar os-bar-build" style="width:62%;left:18%"></div></div>
            </div>
            <div class="os-roadmap-row">
              <div class="os-roadmap-label">Launch<div class="os-roadmap-meta">18 deliveries</div></div>
              <div class="os-roadmap-track"><div class="os-roadmap-bar os-bar-launch" style="width:25%;left:75%"></div></div>
            </div>
          </div>
          <div class="os-roadmap-summary">
            <span>80 deliveries</span><span>4 months</span><span>$108K total</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       6. HOW IT WORKS — Strategy → Launch → Evolve
       ═══════════════════════════════════════════ -->
  <div class="how-it-works">
    <div class="wide-wrap">
      <h2 class="section-heading">How It Works</h2>
      <p class="section-sub">One continuous partnership. We don't hand off — we grow with you.</p>
    </div>
    <div class="steps-grid">
      <div class="step-cell">
        <div class="step-num">1</div>
        <h3>Strategy</h3>
        <span class="step-subtitle">We challenge, shape, and define</span>
        <p>We pressure-test your product thesis — market positioning, regulatory landscape, competitive defensibility. Then we shape the product architecture and define every delivery before the build begins. If something shouldn't be built, we say so.</p>
      </div>
      <div class="step-cell">
        <div class="step-num">2</div>
        <h3>Launch</h3>
        <span class="step-subtitle">We build and ship predictably</span>
        <p>NolteOS translates strategic decisions into working product. Every delivery is scoped, priced, and tracked. Fixed price per delivery — you pay for what ships, and you see progress in real time.</p>
      </div>
      <div class="step-cell">
        <div class="step-num">3</div>
        <h3>Evolve</h3>
        <span class="step-subtitle">We grow the product with you</span>
        <p>Launch is not the end — it's the beginning. We continue to shape strategy, ship features, and evolve the product as the business grows. Our best partnerships are measured in years, not sprints.</p>
      </div>
    </div>
    <a class="steps-cta-inline" href="https://os.nolte.io">
      <span class="steps-cta-action">Build Your Product Roadmap &rarr;</span>
      <span class="steps-cta-sub">Risks, opportunities, and competitive landscape in under 60 seconds</span>
    </a>
  </div>

  <!-- ═══════════════════════════════════════════
       TECH STACK — Technologies we build with
       ═══════════════════════════════════════════ -->
  <div class="trust-bar trust-bar-light">
    <p class="trust-label">Technologies we build with</p>
    <div class="trust-logos">
      <img src="/images/logos/typescript.svg" alt="TypeScript" class="trust-logo-img" />
      <img src="/images/logos/nextjs.svg" alt="Next.js" class="trust-logo-img" />
      <img src="/images/logos/expo.svg" alt="Expo" class="trust-logo-img" />
      <img src="/images/logos/supabase.svg" alt="Supabase" class="trust-logo-img" />
      <img src="/images/logos/aws.svg" alt="AWS" class="trust-logo-img" />
      <img src="/images/logos/figma.svg" alt="Figma" class="trust-logo-img" />
      <img src="/images/logos/anthropic.svg" alt="Claude" class="trust-logo-img" />
      <img src="/images/logos/openai.svg" alt="ChatGPT" class="trust-logo-img" />
      <img src="/images/logos/huggingface.svg" alt="Hugging Face" class="trust-logo-img" />
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       7. CASE STUDIES — Products we shaped and shipped
       ═══════════════════════════════════════════ -->
  <div class="case-studies">
    <h2 class="section-heading">Products we shaped and <em>shipped</em></h2>
    <p class="section-sub">From "should we build this?" to production — in industries where the stakes are real.</p>

    <div class="case-grid">
      <CaseCard slug="breeze-oral-care" image="/images/work/breeze/featured.avif" imageAlt="Breeze Oral Care platform" category="healthcare" client="Breeze Oral Care" description="Strategic workshops, customer development, market positioning, then full build and launch. Discovery to live product in four months — on time, on budget, to the dollar." partnership="2+ years" logo={caseLogos['breeze-oral-care']} />
      <CaseCard slug="pilou" image="/images/work/pilou/featured.png" imageAlt="Pilou financial platform" category="finance" client="Pilou" description="Fintech platform rebuilt under CNBV regulatory requirements. Product strategy, KYC architecture, digital signatures, banking SDK integration — navigating compliance at every step." partnership="2 years" logo={caseLogos['pilou']} />
      <CaseCard slug="odie" image="/images/work/odie/featured.png" imageAlt="Odie pet insurance" category="insurance" client="Odie" description="Pet insurance MGA built from zero under carrier requirements and state regulatory obligations. Product strategy through build — thousands of active policyholders." partnership="3 years" logo={caseLogos['odie']} />
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       TESTIMONIAL
       ═══════════════════════════════════════════ -->
  <div class="home-testimonial-dark">
    <div class="home-testimonial-inner">
      <img src="/images/logos/breeze.svg" alt="Breeze" class="home-testimonial-logo" />
      <blockquote>
        <p>&ldquo;I feel so lucky to work with this brilliant team of people. They can build anything and do so beautifully and on time.&rdquo;</p>
      </blockquote>
      <div class="home-testimonial-attr">
        <img src="/images/work/breeze/josh.jpg" alt="Dr. Joshua Turnbull" class="home-testimonial-avatar" />
        <div class="home-testimonial-attr-text">
          <strong>Dr. Joshua Turnbull</strong>
          <span>CEO at Breeze</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       8. INDUSTRIES — Regulated verticals
       ═══════════════════════════════════════════ -->
  <div class="verticals">
    <h2 class="section-heading">Industries we know <em>deeply</em></h2>
    <p class="section-sub">We build in industries where compliance, timing, and getting it wrong have real consequences. That domain understanding is the foundation of everything we do.</p>

    <div class="verticals-grid">
      <a class="vertical-cell vertical-cell-link" href="/industries/insurance">
        <h3>Insurance</h3>
        <p class="vertical-who">Carriers, MGAs, and insurtechs making product bets under regulatory scrutiny</p>
        <ul class="vertical-items">
          <li>Filing deadlines that regulators set, not product teams</li>
          <li>Platform builds under carrier and state scrutiny</li>
          <li>Legacy systems that can't fail during modernization</li>
        </ul>
        <div class="vertical-compliance">
          <span class="compliance-tag">SOC 2</span>
          <span class="compliance-tag">State Regulatory</span>
        </div>
        <span class="vertical-cta">Learn more &rarr;</span>
      </a>
      <a class="vertical-cell vertical-cell-link" href="/industries/healthcare">
        <h3>Healthcare</h3>
        <p class="vertical-who">Operators building patient-facing digital products for the first time</p>
        <ul class="vertical-items">
          <li>HIPAA compliance that can't be an afterthought</li>
          <li>Clinical integrations with zero tolerance for downtime</li>
          <li>Products where late delivery affects patient outcomes</li>
        </ul>
        <div class="vertical-compliance">
          <span class="compliance-tag">HIPAA</span>
          <span class="compliance-tag">SOC 2</span>
        </div>
        <span class="vertical-cta">Learn more &rarr;</span>
      </a>
      <a class="vertical-cell vertical-cell-link" href="/industries/finance">
        <h3>Finance</h3>
        <p class="vertical-who">Financial operators going digital under compliance constraints</p>
        <ul class="vertical-items">
          <li>Audit trails and compliance baked in from day one</li>
          <li>KYC/AML flows that regulators will scrutinize</li>
          <li>Data handling that meets financial industry standards</li>
        </ul>
        <div class="vertical-compliance">
          <span class="compliance-tag">KYC/AML</span>
          <span class="compliance-tag">SOC 2</span>
        </div>
        <span class="vertical-cta">Learn more &rarr;</span>
      </a>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       9. BLOG / ESSAYS
       ═══════════════════════════════════════════ -->
  <div class="blog-featured">
    <h2 class="section-heading">How we think about building</h2>
    <p class="section-sub">Judgment, delivery methodology, and lessons from building in regulated industries.</p>

    <div class="blog-featured-grid">
      {posts.map(post => (
        <a class="blog-featured-card" href={`/blog/${post.id}`}>
          {post.data.image && <img src={post.data.image} alt={post.data.imageAlt || post.data.title} class="blog-featured-img" />}
          <div class="blog-featured-card-body">
            <span class="blog-featured-category">{post.data.category}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="blog-featured-read">Read article &rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       10. GLOBAL CTA — Product Opportunity Assessment
       ═══════════════════════════════════════════ -->
  <CtaSection />

</Base>
