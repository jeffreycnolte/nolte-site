<script>
  // Feature hover → zone highlight mapping (all sections)
  // Groups features by parent section for independent behavior
  const features = document.querySelectorAll('.snapshot-feature[data-highlight]');
  const sections = new Map();

  features.forEach(feature => {
    const section = feature.closest('.os-product-section');
    if (!sections.has(section)) sections.set(section, []);
    sections.get(section).push(feature);
  });

  // Set first feature in each section as default active
  sections.forEach((sectionFeatures) => {
    const first = sectionFeatures[0];
    if (first) {
      first.classList.add('is-active');
      const zones = document.querySelectorAll(`[data-zone="${first.dataset.highlight}"]`);
      zones.forEach(zone => zone.classList.add('is-highlighted'));
    }
  });

  // Hover: activate hovered, deactivate siblings; on leave: revert to first
  features.forEach(feature => {
    const section = feature.closest('.os-product-section');
    const siblings = sections.get(section) || [];
    const zones = document.querySelectorAll(`[data-zone="${feature.dataset.highlight}"]`);

    feature.addEventListener('mouseenter', () => {
      siblings.forEach(sib => {
        sib.classList.remove('is-active');
        const sibZones = document.querySelectorAll(`[data-zone="${sib.dataset.highlight}"]`);
        sibZones.forEach(z => z.classList.remove('is-highlighted'));
      });
      feature.classList.add('is-active');
      zones.forEach(zone => zone.classList.add('is-highlighted'));
    });

    feature.addEventListener('mouseleave', () => {
      feature.classList.remove('is-active');
      zones.forEach(zone => zone.classList.remove('is-highlighted'));
      const first = siblings[0];
      if (first) {
        first.classList.add('is-active');
        const firstZones = document.querySelectorAll(`[data-zone="${first.dataset.highlight}"]`);
        firstZones.forEach(z => z.classList.add('is-highlighted'));
      }
    });
  });
</script>

