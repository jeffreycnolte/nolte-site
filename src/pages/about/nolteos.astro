---
import Base from '../../layouts/Base.astro';
---
<Base title="NolteOS" description="The delivery operating system that powers predictable, forecast-based software delivery. Real-time visibility into every deliverable, decision, and metric — for you and your team." fullWidth>

  <!-- HERO -->
  <div class="os-hero">
    <div class="wide-wrap">
      <span class="os-eyebrow">The Delivery Operating System</span>
      <h1>Complete visibility into<br><em>every delivery</em></h1>
      <p class="os-hero-sub">NolteOS is how we manage your engagement —<br>and how you stay in control of it.</p>
      <p class="os-hero-closing">No status meetings required.</p>
      <div class="os-hero-pills">
        <span class="os-hero-pill">Real-Time Metrics</span>
        <span class="os-hero-pill">Decision Tracking</span>
        <span class="os-hero-pill">Weekly Delivery Status</span>
      </div>
      <div class="hero-actions" style="justify-content: center;">
        <a class="btn-hero btn-hero-primary" href="https://os.nolte.io">Build a Predictable Plan</a>
      </div>
    </div>
  </div>

  <!-- PRODUCT SHOT 1: PROJECT SNAPSHOT -->
  <div class="os-product-section">
    <div class="os-product-row">
      <div class="os-product-callout">
        <span class="os-callout-label nolte-eyebrow--with-line">Project Snapshot</span>
        <h2>Know where your project stands — <em>always</em></h2>
        <p>Every engagement opens to a live snapshot: your active objective, engagement model, velocity, and key stakeholders. No digging through threads or waiting for a status call.</p>
        <div class="snapshot-features">
          <div class="snapshot-feature" data-highlight="objective">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">Active objective</strong>
              <span class="snapshot-feature-desc">The single goal your team is working toward, with a target date</span>
            </div>
          </div>
          <div class="snapshot-feature" data-highlight="engagement">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">Engagement model</strong>
              <span class="snapshot-feature-desc">Your delivery velocity and what it covers</span>
            </div>
          </div>
          <div class="snapshot-feature" data-highlight="stakeholders">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">Stakeholders</strong>
              <span class="snapshot-feature-desc">Who's involved, always visible</span>
            </div>
          </div>
        </div>
      </div>
      <div class="os-product-shot">
        <div class="shot-window">
          <div class="shot-toolbar">
            <span class="shot-dot"></span><span class="shot-dot"></span><span class="shot-dot"></span>
          </div>
          <div class="shot-content shot-snapshot-rows">
            <div class="shot-snapshot-header-bar">
              <div class="shot-snapshot-icon">B</div>
              <div>
                <div class="shot-snapshot-company">Breeze Oral Care</div>
                <div class="shot-snapshot-company-desc">HIPAA-compliant dental platform with clinical workflow integrations and patient portal.</div>
              </div>
            </div>
            <div class="shot-snapshot-row-full" data-zone="objective" data-label="Active Objective">
              <span class="shot-snapshot-label">Active Objective (Q2 2026)</span>
              <p class="shot-snapshot-text">Launch provider onboarding flow and insurance verification module by June 15, 2026</p>
            </div>
            <div class="shot-snapshot-row-split">
              <div class="shot-snapshot-col" data-zone="engagement" data-label="Engagement Model">
                <span class="shot-snapshot-label">Engagement</span>
                <span class="shot-snapshot-val">Velocity &mdash; 24 items/mo</span>
              </div>
              <div class="shot-snapshot-col" data-zone="stakeholders" data-label="Stakeholders">
                <span class="shot-snapshot-label">Stakeholders</span>
                <div class="shot-avatars shot-avatars-overlap">
                  <span class="shot-avatar shot-avatar-purple">JT</span>
                  <span class="shot-avatar shot-avatar-green">JN</span>
                  <span class="shot-avatar shot-avatar-blue">YL</span>
                  <span class="shot-avatar-more">+2</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="nolte-why-matters os-product-why">
        <span class="nolte-why-label">Why it matters</span>
        <p>You should never have to ask "what are we working on?" The answer is always on your dashboard.</p>
      </div>
    </div>
  </div>

  <!-- PRODUCT SHOT 2: DELIVERY METRICS -->
  <div class="os-product-section os-product-dark">
    <div class="os-product-row reverse">
      <div class="os-product-callout">
        <span class="os-callout-label nolte-eyebrow--with-line">Delivery Metrics</span>
        <h2>Data that tells you if you're on track — <em>not opinions</em></h2>
        <p>Four numbers that matter. Updated in real time. Delivered this week, monthly progress against target, remaining items, and required weekly pace. When pace changes, you see it before it becomes a problem.</p>
        <div class="snapshot-features">
          <div class="snapshot-feature" data-highlight="metrics-weekly">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">Weekly delivery count</strong>
              <span class="snapshot-feature-desc">What actually shipped, not what's "almost done"</span>
            </div>
          </div>
          <div class="snapshot-feature" data-highlight="metrics-monthly">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">Monthly progress</strong>
              <span class="snapshot-feature-desc">Percentage against the forecasted target</span>
            </div>
          </div>
          <div class="snapshot-feature" data-highlight="metrics-pace">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">Required pace</strong>
              <span class="snapshot-feature-desc">The math on what it takes to hit your timeline</span>
            </div>
          </div>
        </div>
      </div>
      <div class="os-product-shot">
        <div class="shot-window shot-window-dark">
          <div class="shot-toolbar">
            <span class="shot-dot"></span><span class="shot-dot"></span><span class="shot-dot"></span>
          </div>
          <div class="shot-content">
            <div class="shot-metrics-grid">
              <div class="shot-metric-card" data-zone="metrics-weekly" data-label="Weekly Delivery">
                <span class="shot-metric-label">Delivered This Week</span>
                <span class="shot-metric-val">10</span>
                <span class="shot-metric-trend positive">Up from 6 last week</span>
              </div>
              <div class="shot-metric-card" data-zone="metrics-monthly" data-label="Monthly Progress">
                <span class="shot-metric-label">March Total</span>
                <span class="shot-metric-val">16 <span class="shot-metric-of">of 34</span></span>
                <span class="shot-metric-trend">47% of target</span>
              </div>
              <div class="shot-metric-card">
                <span class="shot-metric-label">Items Remaining</span>
                <span class="shot-metric-val">18</span>
                <span class="shot-metric-trend">2 weeks left in March</span>
              </div>
              <div class="shot-metric-card" data-zone="metrics-pace" data-label="Required Pace">
                <span class="shot-metric-label">Required Weekly Pace</span>
                <span class="shot-metric-val">9.0</span>
                <span class="shot-metric-trend positive">Down from 9.3</span>
              </div>
            </div>
            <div class="shot-progress">
              <div class="shot-progress-label">March Delivery Progress</div>
              <div class="shot-progress-bar">
                <div class="shot-progress-fill" style="width: 47%;"></div>
                <div class="shot-progress-marker" style="left: 50%;"></div>
              </div>
              <div class="shot-progress-legend">
                <span>47% delivered</span>
                <span class="shot-progress-expected">Expected: 50%</span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="nolte-why-matters os-product-why">
        <span class="nolte-why-label">Why it matters</span>
        <p>Forecasts mean nothing without accountability. These metrics are how we hold ourselves to the plan.</p>
      </div>
    </div>
  </div>

  <!-- PRODUCT SHOT 3: KANBAN FLOW -->
  <div class="os-product-section">
    <div class="os-product-row">
      <div class="os-product-callout">
        <span class="os-callout-label nolte-eyebrow--with-line">Kanban Flow</span>
        <h2>See every deliverable move through the <em>pipeline</em></h2>
        <p>Seven stages from specification to done. Click any stage to see every item in it. No ambiguity about where things are or what's blocking them. Flags surface immediately — blocked items, pending approvals, client dependencies.</p>
        <div class="snapshot-features">
          <div class="snapshot-feature" data-highlight="kanban-stages">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">7 clear stages</strong>
              <span class="snapshot-feature-desc">Awaiting Spec → In Spec → Ready → In Progress → Done Implementing → Validation → Done</span>
            </div>
          </div>
          <div class="snapshot-feature" data-highlight="kanban-clickable">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">Clickable stages</strong>
              <span class="snapshot-feature-desc">Expand any column to see item details</span>
            </div>
          </div>
          <div class="snapshot-feature" data-highlight="kanban-flags">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">Real-time flags</strong>
              <span class="snapshot-feature-desc">Blocked items and pending approvals are visible at a glance</span>
            </div>
          </div>
        </div>
      </div>
      <div class="os-product-shot">
        <div class="shot-window">
          <div class="shot-toolbar">
            <span class="shot-dot"></span><span class="shot-dot"></span><span class="shot-dot"></span>
          </div>
          <div class="shot-content">
            <div class="shot-kanban" data-zone="kanban-stages" data-label="Stages">
              <div class="shot-kanban-col">
                <div class="shot-kanban-header">Awaiting Spec<span class="shot-kanban-count">8</span></div>
                <div class="shot-kanban-card">Client Dashboard MVP</div>
                <div class="shot-kanban-card">Provider Search v2</div>
                <div class="shot-kanban-card faded">+6 more</div>
              </div>
              <div class="shot-kanban-col">
                <div class="shot-kanban-header">In Progress<span class="shot-kanban-count">3</span></div>
                <div class="shot-kanban-card">Insurance Verification</div>
                <div class="shot-kanban-card flagged" data-zone="kanban-flags" data-label="Flags">
                  AWS Migration
                  <span class="shot-flag blocked">Blocked</span>
                </div>
                <div class="shot-kanban-card">Auth Flow v2</div>
              </div>
              <div class="shot-kanban-col" data-zone="kanban-clickable" data-label="Details">
                <div class="shot-kanban-header">Validation<span class="shot-kanban-count">2</span></div>
                <div class="shot-kanban-card">Onboarding Wizard</div>
                <div class="shot-kanban-card flagged">
                  Dashboard Design
                  <span class="shot-flag pending">Pending Approval</span>
                </div>
              </div>
              <div class="shot-kanban-col done">
                <div class="shot-kanban-header">Done This Week<span class="shot-kanban-count">10</span></div>
                <div class="shot-kanban-card">Plan Calculator</div>
                <div class="shot-kanban-card">Lead Capture Flow</div>
                <div class="shot-kanban-card faded">+8 more</div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="nolte-why-matters os-product-why">
        <span class="nolte-why-label">Why it matters</span>
        <p>You should be able to answer "where is my feature?" in under five seconds.</p>
      </div>
    </div>
  </div>

  <!-- PRODUCT SHOT 4: DECISIONS & APPROVALS -->
  <div class="os-product-section os-product-dark">
    <div class="os-product-row reverse">
      <div class="os-product-callout">
        <span class="os-callout-label nolte-eyebrow--with-line">Decisions &amp; Approvals</span>
        <h2>Every decision recorded. Nothing <em>lost.</em></h2>
        <p>Meetings produce decisions and agreements. NolteOS captures them automatically — who decided what, when, and what action items came out of it. Pending approvals surface in your dashboard with due dates so you can act on your schedule.</p>
        <div class="snapshot-features">
          <div class="snapshot-feature" data-highlight="approvals-history">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">Decision history</strong>
              <span class="snapshot-feature-desc">Searchable record of every decision across every meeting</span>
            </div>
          </div>
          <div class="snapshot-feature" data-highlight="approvals-async">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">Async approvals</strong>
              <span class="snapshot-feature-desc">Approve directly from your dashboard, no meeting needed</span>
            </div>
          </div>
          <div class="snapshot-feature" data-highlight="approvals-actions">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">Action items</strong>
              <span class="snapshot-feature-desc">Auto-generated from meeting transcripts, assigned and tracked</span>
            </div>
          </div>
        </div>
      </div>
      <div class="os-product-shot">
        <div class="shot-window shot-window-dark">
          <div class="shot-toolbar">
            <span class="shot-dot"></span><span class="shot-dot"></span><span class="shot-dot"></span>
          </div>
          <div class="shot-content">
            <div class="shot-approvals">
              <div class="shot-approval-group" data-zone="approvals-history" data-label="Decision History">
                <div class="shot-approval-row">
                  <div class="shot-approval-status approved">Approved</div>
                  <div class="shot-approval-info">
                    <div class="shot-approval-title">Calculator — Shipped & Approved</div>
                    <div class="shot-approval-detail">All 7 stories delivered. Epic complete.</div>
                  </div>
                  <div class="shot-approval-date">Mar 14</div>
                </div>
                <div class="shot-approval-row">
                  <div class="shot-approval-status approved">Approved</div>
                  <div class="shot-approval-info">
                    <div class="shot-approval-title">Design Direction — Blue Palette</div>
                    <div class="shot-approval-detail">Approved in Feb 26 design review.</div>
                  </div>
                  <div class="shot-approval-date">Feb 26</div>
                </div>
              </div>
              <div class="shot-approval-group" data-zone="approvals-async" data-label="Async Approval">
                <div class="shot-approval-row highlight">
                  <div class="shot-approval-status pending-status">Pending</div>
                  <div class="shot-approval-info">
                    <div class="shot-approval-title">Client Dashboard Design</div>
                    <div class="shot-approval-detail">Approval needed to move 2 stories to ready.</div>
                  </div>
                  <div class="shot-approval-action">
                    <button class="shot-approve-btn">Approve</button>
                  </div>
                </div>
                <div class="shot-approval-row highlight">
                  <div class="shot-approval-status pending-status">Pending</div>
                  <div class="shot-approval-info">
                    <div class="shot-approval-title">20% Bonus Capacity Model</div>
                    <div class="shot-approval-detail">Capacity benchmark complete. Due Mar 24.</div>
                  </div>
                  <div class="shot-approval-action">
                    <button class="shot-approve-btn">Approve</button>
                  </div>
                </div>
              </div>
              <div class="shot-action-items" data-zone="approvals-actions" data-label="Action Items">
                <div class="shot-action-header">Action Items</div>
                <div class="shot-action-row">
                  <span class="shot-action-icon">→</span>
                  <div class="shot-action-info">
                    <div class="shot-action-title">Update provider API docs before integration begins</div>
                    <div class="shot-action-meta">Assigned to JN &middot; Due Mar 28</div>
                  </div>
                </div>
                <div class="shot-action-row">
                  <span class="shot-action-icon">→</span>
                  <div class="shot-action-info">
                    <div class="shot-action-title">Schedule design review for dashboard MVP with client</div>
                    <div class="shot-action-meta">Assigned to YL &middot; Due Mar 26</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="nolte-why-matters os-product-why">
        <span class="nolte-why-label">Why it matters</span>
        <p>"What did we decide?" is the most expensive question in software. You'll never need to ask it.</p>
      </div>
    </div>
  </div>

  <!-- PRODUCT SHOT 5: MEETING INTELLIGENCE -->
  <div class="os-product-section">
    <div class="os-product-row">
      <div class="os-product-callout">
        <span class="os-callout-label nolte-eyebrow--with-line">Meeting Intelligence</span>
        <h2>Meetings that produce <em>outcomes</em>, not confusion</h2>
        <p>Every meeting is transcribed and processed into structured decisions, agreements, and action items. Recaps are finalized and shareable. Work items are generated directly from what was agreed — no manual translation.</p>
        <div class="snapshot-features">
          <div class="snapshot-feature" data-highlight="meeting-recaps">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">Structured recaps</strong>
              <span class="snapshot-feature-desc">Decisions, agreements, and action items extracted automatically</span>
            </div>
          </div>
          <div class="snapshot-feature" data-highlight="meeting-history">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">Searchable history</strong>
              <span class="snapshot-feature-desc">Find any decision from any meeting instantly</span>
            </div>
          </div>
          <div class="snapshot-feature" data-highlight="meeting-workitems">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">Work item generation</strong>
              <span class="snapshot-feature-desc">Agreements become deliverables with one click</span>
            </div>
          </div>
        </div>
      </div>
      <div class="os-product-shot">
        <div class="shot-window">
          <div class="shot-toolbar">
            <span class="shot-dot"></span><span class="shot-dot"></span><span class="shot-dot"></span>
          </div>
          <div class="shot-content">
            <div class="shot-meeting">
              <div class="shot-meeting-search" data-zone="meeting-history" data-label="Searchable History">
                <span class="shot-search-icon">&#128269;</span>
                <span class="shot-search-text">Search decisions, agreements, action items...</span>
              </div>
              <div class="shot-meeting-header">
                <div class="shot-meeting-title">Weekly Delivery Meeting</div>
                <div class="shot-meeting-date">March 17, 2026</div>
              </div>
              <div class="shot-meeting-tags" data-zone="meeting-recaps" data-label="Structured Recaps">
                <span class="shot-tag decisions">4 Decisions</span>
                <span class="shot-tag agreements">5 Agreements</span>
                <span class="shot-tag actions">5 Action Items</span>
              </div>
              <div class="shot-meeting-items">
                <div class="shot-decision-row">
                  <span class="shot-decision-icon">D</span>
                  <span>Use dashboard as client-facing view</span>
                </div>
                <div class="shot-decision-row">
                  <span class="shot-decision-icon">D</span>
                  <span>Apply design system globally</span>
                </div>
                <div class="shot-decision-row agreement">
                  <span class="shot-decision-icon a">A</span>
                  <span>Dashboard should be self-explanatory — no training needed</span>
                </div>
                <div class="shot-decision-row agreement">
                  <span class="shot-decision-icon a">A</span>
                  <span>Add "Expected Next Week" section with flags</span>
                </div>
              </div>
              <div class="shot-meeting-recap">
                <span class="shot-recap-badge">Recap Finalized</span>
                <span class="shot-recap-actions">Edit &middot; Share</span>
                <button class="shot-generate-btn" data-zone="meeting-workitems" data-label="Work Items">Generate Work Items</button>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="nolte-why-matters os-product-why">
        <span class="nolte-why-label">Why it matters</span>
        <p>The gap between "what we discussed" and "what we're building" is where most projects fail. NolteOS closes it.</p>
      </div>
    </div>
  </div>

  <!-- PRODUCT SHOT 6: WEEKLY DELIVERY STATUS -->
  <div class="os-product-section os-product-dark">
    <div class="os-product-row reverse">
      <div class="os-product-callout">
        <span class="os-callout-label nolte-eyebrow--with-line">Weekly Delivery Status</span>
        <h2>What shipped. What's next. <em>What's flagged.</em></h2>
        <p>Every week, your dashboard shows exactly what was delivered, grouped by epic. Next to it: what's expected next week, with flags for anything blocked or waiting on you. This is the heartbeat of your engagement.</p>
        <div class="snapshot-features">
          <div class="snapshot-feature" data-highlight="delivery-shipped">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">Delivered this week</strong>
              <span class="snapshot-feature-desc">Grouped by epic, with item-level detail</span>
            </div>
          </div>
          <div class="snapshot-feature" data-highlight="delivery-next">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">Expected next week</strong>
              <span class="snapshot-feature-desc">What's coming, with blocker and approval flags</span>
            </div>
          </div>
          <div class="snapshot-feature" data-highlight="delivery-pace">
            <span class="snapshot-feature-dot"></span>
            <div>
              <strong class="snapshot-feature-name">Weekly pace tracking</strong>
              <span class="snapshot-feature-desc">Actual vs. target, updated in real time</span>
            </div>
          </div>
        </div>
      </div>
      <div class="os-product-shot">
        <div class="shot-window shot-window-dark">
          <div class="shot-toolbar">
            <span class="shot-dot"></span><span class="shot-dot"></span><span class="shot-dot"></span>
          </div>
          <div class="shot-content">
            <div class="shot-delivery-cols">
              <div class="shot-delivery-col" data-zone="delivery-shipped" data-label="Delivered">
                <div class="shot-delivery-heading">Delivered This Week <span class="shot-delivery-count">10</span></div>
                <div class="shot-epic-group">
                  <span class="shot-epic-name">Product Calculator</span>
                  <div class="shot-delivery-item done">&#10003; Structured Delivery Plan</div>
                  <div class="shot-delivery-item done">&#10003; Lead Capture Flow</div>
                  <div class="shot-delivery-item done">&#10003; Follow-Up Automations</div>
                  <div class="shot-delivery-item done">&#10003; Design Refinement</div>
                  <div class="shot-delivery-item faded">+3 more items</div>
                </div>
                <div class="shot-epic-group">
                  <span class="shot-epic-name">AI Infrastructure</span>
                  <div class="shot-delivery-item done">&#10003; Otto Agent E2E</div>
                  <div class="shot-delivery-item done">&#10003; Docker + GitHub PR</div>
                  <div class="shot-delivery-item done">&#10003; Slack Execution</div>
                </div>
              </div>
              <div class="shot-delivery-col" data-zone="delivery-next" data-label="Expected Next">
                <div class="shot-delivery-heading">Expected Next Week <span class="shot-delivery-count">9</span></div>
                <div class="shot-delivery-item">Otto on AWS Fargate</div>
                <div class="shot-delivery-item flag-blocked">
                  <span>Provider API Integration</span>
                  <span class="shot-inline-flag blocked">Blocked</span>
                </div>
                <div class="shot-delivery-item">Dashboard MVP Build</div>
                <div class="shot-delivery-item flag-pending">
                  <span>Project Snapshot Surface</span>
                  <span class="shot-inline-flag pending">Pending Approval</span>
                </div>
                <div class="shot-delivery-item">Klipster AI Readiness</div>
                <div class="shot-delivery-item faded">+4 more items</div>
              </div>
            </div>
            <div class="shot-pace-tracker" data-zone="delivery-pace" data-label="Weekly Pace">
              <div class="shot-pace-weeks">
                <div class="shot-pace-week">
