---
/**
 * Press coverage bar — shows publication logos + pull quotes.
 * Used on case study pages when frontmatter includes `press` array.
 * Logos are stored in /public/images/press/ and mapped by publication slug.
 */
interface PressItem {
  publication: string;
  headline: string;
  quote: string;
  url: string;
}

interface Props {
  items: PressItem[];
}

const { items } = Astro.props;

// Map publication names to logo files
const logoMap: Record<string, string> = {
  'HousingWire':   '/images/press/housingwire.svg',
  'Yahoo Finance': '/images/press/yahoo-finance.svg',
  'Inman':         '/images/press/inman.svg',
  'AM New York':   '/images/press/amnewyork.svg',
  'The Real Deal': '/images/press/therealdeal.svg',
  'New York Post': '/images/press/nypost.svg',
  'PR Newswire':   '/images/press/prnewswire.svg',
};
---

<div class="press-section">
  <div class="press-inner">
    <span class="press-label">In the Press</span>
    <div class="press-quotes">
      {items.map(item => (
        <a class="press-quote" href={item.url} target="_blank" rel="noopener">
          {logoMap[item.publication] ? (
            <img src={logoMap[item.publication]} alt={item.publication} class="press-logo" />
          ) : (
            <span class="press-publication">{item.publication}</span>
          )}
          <p class="press-text">&ldquo;{item.quote}&rdquo;</p>
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  .press-section {
    background: var(--gray-100);
    padding: 4rem 2rem;
  }
  .press-inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .press-label {
    display: block;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--gray-400);
    margin-bottom: 2rem;
    text-align: center;
  }
  .press-quotes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1px;
    background: var(--gray-200);
  }
  .press-quote {
    background: var(--white);
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: background 0.15s;
  }
  .press-quote:hover {
    background: var(--gray-100);
  }
  .press-logo {
    height: 18px;
    width: auto;
    max-width: 140px;
    object-fit: contain;
    filter: grayscale(100%) brightness(0);
    opacity: 0.5;
    align-self: flex-start;
  }
  .press-publication {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--gray-400);
  }
  .press-text {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-style: italic;
    line-height: 1.4;
    color: var(--black);
    margin: 0;
  }
</style>
