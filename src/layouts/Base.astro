---
import BaseHead from '../components/BaseHead.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  updatedDate?: Date;
  author?: string;
  fullWidth?: boolean;
  noindex?: boolean;
}
const {
  title,
  description,
  image,
  imageAlt,
  type,
  publishedDate,
  updatedDate,
  author,
  fullWidth = false,
  noindex = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '';

function isActive(path: string) {
  return currentPath === path || currentPath === path + '/' || currentPath.startsWith(path + '/');
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <BaseHead
    title={title}
    description={description}
    image={image}
    imageAlt={imageAlt}
    type={type}
    publishedDate={publishedDate}
    updatedDate={updatedDate}
    author={author}
    noindex={noindex}
  />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Nolte",
    "url": Astro.site?.href,
    "description": "Consultative product partner for regulated industries. We evolve ambitious ideas into shipped products — when getting it wrong is not an option.",
    "foundingDate": "2016",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "contact@nolte.io",
      "contactType": "sales"
    },
    "sameAs": [
      "https://www.linkedin.com/company/nolte/"
    ],
    "founder": [
      {
        "@type": "Person",
        "name": "Jeffrey Nolte",
        "jobTitle": "Managing Director",
        "sameAs": "https://www.linkedin.com/in/jeffreynolte/"
      }
    ],
    "knowsAbout": ["software delivery", "product strategy", "regulated industries", "healthcare technology", "insurance technology", "financial technology"]
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Nolte",
    "url": Astro.site?.href,
    "description": "Consultative product partner for regulated industries.",
    "publisher": {
      "@type": "Organization",
      "name": "Nolte"
    }
  })} />
</head>
<body>

<nav class={isHome ? 'nav-dark' : undefined}>
  <div class="inner">
    <a class="wordmark" href="/"><img src="/images/logos/nolte-black.svg" alt="Nolte" class="nav-logo" /><img src="/images/logos/nolte-white.svg" alt="Nolte" class="nav-logo-white" /></a>
    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <div class="nav-links">
      <a href="/work" aria-current={isActive('/work') ? 'page' : undefined}>Work</a>
      <a href="/contact" aria-current={isActive('/contact') ? 'page' : undefined}>Let's Talk</a>
      <a href="https://os.nolte.io" class="nav-cta">Build Your Roadmap</a>
    </div>
  </div>
</nav>

{fullWidth ? <slot /> : <div class="page-wrap"><slot /></div>}

<footer>
  <div class="footer-grid">
    <div class="footer-col">
      <img src="/images/logos/nolte-black.svg" alt="Nolte" class="footer-logo" />
      <p class="footer-tagline">We evolve ambitious ideas into shipped products — when getting it wrong is not an option.</p>
      <a href="https://www.linkedin.com/company/nolte/" target="_blank" rel="noopener">LinkedIn</a>
    </div>
    <div class="footer-col">
      <h4>Company</h4>
      <a href="/about/nolteos">NolteOS</a>
      <a href="/contact">Contact</a>
    </div>
    <div class="footer-col">
      <h4>Work</h4>
      <a href="/work">Case Studies</a>
      <a href="/delivery">Delivery Model</a>
    </div>
    <div class="footer-col">
      <h4>Resources</h4>
      <a href="/blog">Blog</a>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; {new Date().getFullYear()} Nolte &mdash; nolte.io</p>
  </div>
</footer>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const links = document.querySelector('.nav-links');
  if (toggle && links) {
    toggle.addEventListener('click', () => {
      const open = links.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(open));
    });
  }

  // PostHog custom events
  if (window.posthog) {
    // Track all CTA clicks to os.nolte.io
    document.querySelectorAll('a[href*="os.nolte.io"]').forEach(el => {
      el.addEventListener('click', () => {
        posthog.capture('cta_clicked', {
          location: el.closest('.hero-dark') ? 'hero' :
                    el.closest('.predictability-cta') ? 'footer_cta' :
                    el.closest('.steps-cta-inline') ? 'steps_cta' :
                    el.closest('nav') ? 'nav' :
                    el.closest('.nolteos-callout') ? 'nolteos_section' :
                    'other',
          text: el.textContent.trim()
        });
      });
    });

    // Track case study clicks
    document.querySelectorAll('a[href*="/work/"]').forEach(el => {
      el.addEventListener('click', () => {
        posthog.capture('case_study_clicked', {
          study: el.getAttribute('href'),
          from: window.location.pathname
        });
      });
    });

    // Track blog post clicks
    document.querySelectorAll('a[href*="/blog/"]').forEach(el => {
      el.addEventListener('click', () => {
        posthog.capture('blog_clicked', {
          post: el.getAttribute('href'),
          from: window.location.pathname
        });
      });
    });
  }
</script>

</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
